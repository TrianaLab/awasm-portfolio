# Frontend branding — copy to .env.local (gitignored) and edit to deploy
# your own portfolio. All variables must start with VITE_ to be exposed
# to the client bundle. See frontend/src/lib/config.ts for the defaults.

# Short brand used in the page <title>, e.g. "edudiaz" → tab shows
# "edudiaz - awasm portfolio".
VITE_BRAND=edudiaz

# Full domain shown as the brand mark in the top-left, the terminal
# prompt, and other public-facing places.
VITE_DOMAIN=edudiaz.dev

# Owner/Name of the GitHub repository surfaced by the top-right card
# (version + stars + forks).
VITE_GITHUB_REPO=TrianaLab/awasm-portfolio
